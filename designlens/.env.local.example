# Anthropic (Claude) — required for AI analysis, UI review, and enhancement suggestions.
ANTHROPIC_API_KEY=your_key_here

# OpenAI — required ONLY for the "Show Improvements" AI-generated before/after image
# (gpt-image-1). Without it, enhancement suggestions still work and the review falls
# back to annotation overlays instead of a generated image.
OPENAI_API_KEY=your_key_here

# Optional: explicit Chrome/Chromium path for local URL capture (auto-detected otherwise).
# CHROME_PATH=C:/Program Files/Google/Chrome/Application/chrome.exe
